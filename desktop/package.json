{
  "name": "keobot-desktop",
  "productName": "KeoBot",
  "version": "0.3.0",
  "private": true,
  "description": "Vietnamese speech-to-speech AI assistant desktop app.",
  "author": "Kieu Thien Quy",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "smoke:packaged": "node scripts/smoke_packaged_app.js"
  },
  "build": {
    "appId": "com.keobot.desktop",
    "productName": "KeoBot",
    "directories": {
      "output": "../release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "../frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend",
        "filter": [
          "keobot_backend/**/*"
        ]
      }
    ],
    "portable": {
      "artifactName": "KeoBot-Portable-v${version}.${ext}"
    },
    "nsis": {
      "artifactName": "KeoBot-Setup-v${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.1"
  }
}
